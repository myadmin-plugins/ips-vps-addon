{
	"name": "detain/myadmin-ips-vps-addon",
	"type": "myadmin-plugin",
	"description": "Additional IP address addon module for VPS services in the MyAdmin hosting control panel. Provides IP allocation, assignment, and lifecycle management for virtual private servers.",
	"keywords": [
		"ips",
		"vps",
		"addon",
		"myadmin",
		"ip-management",
		"hosting",
		"administration"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"homepage": "https:\/\/my.interserver.net\/"
		}
	],
	"config": {
		"bin-dir": "vendor\/bin",
		"minimum-stability": "dev"
	},
	"require": {
		"php": ">=5.0.0",
		"ext-soap": "*",
		"symfony/event-dispatcher": "^5.0@stable",
		"detain/myadmin-plugin-installer": "dev-master"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"Detain\\MyAdminVpsIps\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\MyAdminVpsIps\\Tests\\": "tests/"
		}
	}
}
